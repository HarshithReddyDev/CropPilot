# CropPilot Frontend Configuration

# Backend API URL (defaults to http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mapbox Access Token (required for Maps page)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# Default map style
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/satellite-streets-v12
