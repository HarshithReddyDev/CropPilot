# CropPilot Backend Configuration

# App
APP_NAME=CropPilot
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Security
SECRET_KEY=change-this-to-a-strong-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=croppilot
POSTGRES_PASSWORD=croppilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=croppilot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenWeather
OPENWEATHER_API_KEY=your-openweather-api-key

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=croppilot-backend

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# AWS
AWS_REGION=ap-south-1
AWS_S3_BUCKET=croppilot-media

# Celery
CELERY_WORKER_CONCURRENCY=4

# Logging
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true
